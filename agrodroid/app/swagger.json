        "security": [{ "bearerAuth": [] }],
        "parameters": [{ "name": "id", "in": "path", "required": true, "schema": { "type": "integer" } }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "oneOf": [
                  { "$ref": "#/components/schemas/AlertaEstadoPorNombre" },
                  { "$ref": "#/components/schemas/AlertaEstadoPorId" }
                ]
              },
              "examples": {
                "por_nombre": { "value": { "estado": "En Proceso" } },
                "por_id_legacy": { "value": { "estadoalerta_idestado": 3 } }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Estado actualizado", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Alerta" } } } },
          "400": { "description": "Estado de alerta desconocido (string no encontrado)", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } } },
          "404": { "description": "Alerta no encontrada", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } } }
